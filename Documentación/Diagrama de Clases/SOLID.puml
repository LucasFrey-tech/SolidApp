@startuml SOLID_DB_FINAL

left to right direction
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

' ===================== USUARIOS =====================
package "USUARIOS" {

class Usuario {
    -id: int
    -correo: string
    -clave: string
    -nombre: string
    -apellido: string
    -rol: string
    -puntos: int
    -habilitado: boolean
    -verificado: boolean
    -fecha_registro: datetime
    -ultima_conexion: datetime
    -ultimo_cambio: datetime
}

class Donador {
    -id: int
    -puntos: int
    -id_usuario: int
}

class RankingDonador {
    -id_usuario: int
    -puntos: int
}

class EmpresaUsuario {
    -id: int
    -id_usuario: int
    -id_empresa: int
    -rol: string
    -activo: boolean
    -fecha_asignacion: datetime
}

class OrganizacionUsuario {
    -id: int
    -id_usuario: int
    -id_organizacion: int
    -rol: string
    -activo: boolean
    -fecha_asignacion: datetime
}

class Invitacion {
    -id: int
    -token: string
    -correo: string
    -empresaId: int
    -organizacionId: int
    -invitadorId: int
    -rol: string
    -expirada: boolean
    -fecha_creacion: datetime
    -fecha_expiracion: datetime
}

}

' ===================== EMPRESAS =====================
package "EMPRESAS" {

class Empresa {
    -id: int
    -cuit: string
    -razon_social: string
    -nombre_empresa: string
    -descripcion: string
    -rubro: string
    -web: string
    -verificada: boolean
    -habilitada: boolean
    -fecha_registro: datetime
    -ultimo_cambio: datetime
    -creado_por_id: int
    -actualizado_por_id: int
}

class Beneficio {
    -id: int
    -titulo: string
    -tipo: string
    -detalle: string
    -cantidad: int
    -valor: int
    -estado: string
    -fecha_registro: datetime
    -ultimo_cambio: datetime
    -creado_por_id: int
    -actualizado_por_id: int
}

class UsuarioBeneficio {
    -id: int
    -id_usuario: int
    -id_beneficio: int
    -cantidad: int
    -usados: int
    -estado: string
    -fecha_reclamo: datetime
    -fecha_uso: datetime
    -ultimo_cambio: datetime
}

class Imagen_Empresa {
    -id: int
    -logo: string
    -banner: string
}

class Imagen_Beneficio {
    -id: int
    -imagen: string
}

}

' ===================== ORGANIZACIONES =====================
package "ORGANIZACIONES" {

class Organizacion {
    -id: int
    -cuit: string
    -razon_social: string
    -nombre_organizacion: string
    -descripcion: string
    -web: string
    -verificada: boolean
    -habilitada: boolean
    -fecha_registro: datetime
    -ultimo_cambio: datetime
    -creado_por_id: int
    -actualizado_por_id: int
}

class Imagen_Organizacion {
    -id: int
    -logo: string
    -banner: string
}

}

' ===================== CAMPAÑAS =====================
package "CAMPAÑAS" {

class Campaña {
    -id: int
    -estado: string
    -titulo: string
    -descripcion: string
    -fecha_inicio: date
    -fecha_fin: date
    -objetivo: int
    -puntos: int
    -fecha_registro: datetime
    -ultimo_cambio: datetime
    -creado_por_id: int
    -actualizado_por_id: int
}

class Imagen_Campaña {
    -id: int
    -imagen: string
    -esPortada: boolean
}

}

' ===================== DONACIONES =====================
package "DONACIONES" {

class Donacion {
    -id: int
    -titulo: string
    -detalle: string
    -tipo: string
    -cantidad: int
    -estado: string
    -puntos: int
    -fecha_registro: datetime
    -fecha_aprobacion: datetime
    -fecha_rechazo: datetime
    -motivo_rechazo: string
    -creado_por_id: int
    -aprobado_por_id: int
    -rechazado_por_id: int
}

class Imagen_Donacion {
    -id: int
    -imagen: string
}

}

' ===================== RELACIONES =====================

Usuario "1" -right- "1" Donador
Usuario "1" -right- "1" RankingDonador

Usuario "1" -down- "0..*" EmpresaUsuario
Usuario "1" -down- "0..*" OrganizacionUsuario
Usuario "1" -down- "0..*" UsuarioBeneficio
Usuario "1" -down- "0..*" Donacion

Empresa "1" -down- "0..*" EmpresaUsuario
Empresa "1" -right- "0..*" Beneficio
Empresa "1" -down- "0..*" Imagen_Empresa

Organizacion "1" -down- "0..*" OrganizacionUsuario
Organizacion "1" -right- "0..*" Campaña
Organizacion "1" -down- "0..*" Imagen_Organizacion

Campaña "1" -down- "0..*" Donacion
Campaña "1" -right- "0..*" Imagen_Campaña

Donador "1" -down- "0..*" Donacion

Donacion "1" -right- "0..*" Imagen_Donacion

Beneficio "1" -down- "0..*" UsuarioBeneficio
Beneficio "1" -right- "0..*" Imagen_Beneficio

Usuario "1" -right- "0..*" Invitacion

@enduml